# Python
.venv/
__pycache__/
*.pyc
*.pyo
.python-version

# LaTeX build artefacts
manuscript/*.aux
manuscript/*.bbl
manuscript/*.blg
manuscript/*.fdb_latexmk
manuscript/*.fls
manuscript/*.log
manuscript/*.out
manuscript/*.synctex.gz
manuscript/*.toc
# Compiled manuscript PDF (built by CI on each v* tag)
manuscript/main.pdf
case-study/manuscript/*.aux
case-study/manuscript/*.bbl
case-study/manuscript/*.blg
case-study/manuscript/*.fdb_latexmk
case-study/manuscript/*.fls
case-study/manuscript/*.log
case-study/manuscript/*.out
case-study/manuscript/*.synctex.gz
case-study/manuscript/*.toc
case-study/manuscript/main.pdf

# Raw data (regenerable from documented URLs)
case-study/data/raw/*
!case-study/data/raw/.gitkeep

# Processed artefacts (regenerable)
case-study/data/processed/*.tsv
case-study/data/processed/*.txt
case-study/data/processed/*.csv
case-study/results/*.npz
case-study/results/*.parquet
case-study/results-cache/

# Editor / OS noise
*.swp
.idea/
.vscode/

# Reviewer-log scratch (final logs land under reviewer-logs/round-XX/)
reviewer-logs/scratch/

# Large supplementary files
*.xlsx
!assets/**/*.xlsx

# macOS
.DS_Store
release/
